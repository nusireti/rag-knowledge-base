# ==========================================
# RAG Knowledge Base - 环境配置
# 复制此文件为 .env 并修改配置
# cp .env.example .env
# ==========================================

# ---- 应用 ----
APP_NAME=RAG Knowledge Base
APP_VERSION=1.0.0
DEBUG=false
# 生产环境请替换为随机字符串
SECRET_KEY=change-this-to-a-random-secret-in-production

# ---- 数据库 ----
DATABASE_URL=sqlite:///data/rag.db

# ---- Embedding ----
# local | openai
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# OPENAI_API_KEY=sk-xxx

# ---- LLM ----
# local | openai
LLM_PROVIDER=local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
# OPENAI_LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1

# ---- RAG 参数 ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=6

# ---- 服务器 ----
STREAMLIT_PORT=8501
