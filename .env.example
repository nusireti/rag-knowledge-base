# =============================================
# RAG 智能知识库 - 环境配置
# 复制此文件为 .env 并填写你的配置
# 优先级: 环境变量 > .env 文件 > 默认值
# =============================================

# ---- 应用基础 ----
# APP_NAME="RAG Knowledge Base"
# DEBUG=false
# SECRET_KEY="change-this-to-a-random-secret-in-production"

# ---- Embedding 模型 ----
# local = 本地模型 (BGE), openai = OpenAI API
# EMBEDDING_PROVIDER=local
# LOCAL_EMBEDDING_MODEL="BAAI/bge-small-zh-v1.5"
# OPENAI_API_KEY="sk-..."
# OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# ---- LLM ----
# local = Ollama (本地), openai = OpenAI API
LLM_PROVIDER=local
# Ollama 配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
# OpenAI 配置
# OPENAI_LLM_MODEL="gpt-4o-mini"
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=2048
# LLM_CONTEXT_WINDOW=4096

# ---- RAG ----
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# RETRIEVAL_K=6
# RETRIEVAL_SEARCH_TYPE=similarity
# USE_HYBRID_SEARCH=true
# USE_RERANK=false

# ---- 邮件（验证码/找回密码） ----
# SMTP_ENABLE=false
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER="your@qq.com"
# SMTP_PASSWORD="你的SMTP授权码"
# SMTP_FROM="your@qq.com"
